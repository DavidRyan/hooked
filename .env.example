# Copy this file to `.env` and fill in real values. The compose file reads from
# `.env` automatically. Don't commit `.env` (already gitignored).

# --- Database ---
POSTGRES_PASSWORD=changeme-long-random

# --- Phoenix backend ---
# Generate fresh secrets locally with `cd backend && mix phx.gen.secret`
SECRET_KEY_BASE=
JWT_SECRET=

# The public hostname the backend will be reached at. On the ThinkBook this is
# either the LAN IP, the Tailscale hostname, or "localhost" for testing.
PHX_HOST=localhost
POOL_SIZE=10

# Optional: override the backend's published port (default 4000)
# BACKEND_PORT=4000

# --- AI / external services ---
OPENAI_API_KEY=sk-
OPENWEATHER_API_KEY=
TAVILY_API_KEY=
OPENAI_MODEL=gpt-4o

# --- chat-server ---
# CHAT_PORT=8080

# --- S3 (catch image storage) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
S3_REGION=us-east-1

# --- Optional enrichment integrations ---
MAPBOX_ACCESS_TOKEN=
INATURALIST_ACCESS_TOKEN=
GOOGLE_VISION_ACCESS_TOKEN=
